{
  "name": "@lde/fastify-rdf",
  "version": "0.4.2",
  "description": "Fastify plugin for serving RDF data with content negotiation",
  "repository": {
    "url": "git+https://github.com/ldengine/lde.git",
    "directory": "packages/fastify-rdf"
  },
  "type": "module",
